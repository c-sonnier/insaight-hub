<div class="min-h-screen flex items-center justify-center">
  <div class="card bg-base-100 shadow-xl w-full max-w-md">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold text-center justify-center mb-4">Create Organization</h2>
      <p class="text-center text-base-content/70 mb-6">Set up a new organization to collaborate with your team.</p>

      <%= form_with model: @account, url: accounts_path, class: "space-y-4" do |form| %>
        <% if @account.errors.any? %>
          <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div>
              <ul class="list-disc list-inside">
                <% @account.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <div class="form-control">
          <%= form.label :name, class: "label" do %>
            <span class="label-text">Organization Name</span>
          <% end %>
          <%= form.text_field :name, class: "input input-bordered w-full", placeholder: "Your company or team name", autofocus: true, required: true %>
        </div>

        <div class="form-control mt-6">
          <%= form.submit "Create Organization", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
